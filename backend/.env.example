PORT=4000
DB_HOST=localhost
DB_PORT=1433
DB_NAME=YourDatabase
DB_USER=sa
DB_PASS=YourStrongPassword
DB_ENCRYPT=false
DB_TRUST_SERVER_CERT=true
JWT_SECRET=your-super-secret-key
JWT_EXPIRES_IN=8h
# '*' allows any origin (LAN), or a comma-separated list of allowed origins
CORS_ORIGIN=*
# Enable HTTPS so the browser camera works over a LAN IP. Point to your certs.
HTTPS_ENABLED=false
HTTPS_KEY_PATH=../certs/key.pem
HTTPS_CERT_PATH=../certs/cert.pem
